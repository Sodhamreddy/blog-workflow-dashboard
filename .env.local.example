# ============================================================
# BlogFlow Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ── n8n Webhook Security ──────────────────────────────────────
# Set a strong random string here and in your n8n workflow's
# HTTP Request node header:  x-webhook-secret: <this value>
# Leave blank to disable auth (not recommended for production)
N8N_WEBHOOK_SECRET=change-me-to-a-strong-random-secret

# ── App (optional) ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
